<Window x:Class="SuperLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SuperLauncher" xmlns:elements="clr-namespace:SuperLauncher.Elements"
        mc:Ignorable="d"
        Title="Super Launcher" Height="450" Width="800" WindowStyle="None" AllowsTransparency="True" Visibility="Visible">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <WrapPanel Margin="0,0,10,10">
                <local:AppIconMain></local:AppIconMain>
            </WrapPanel>
        </ScrollViewer>
    </Grid>
</Window>
